{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["@types/node", "bun"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "libghosty": ["../third_party/libghostty/lib"],
      "fs/promises": ["./src/shims/fs-promises.ts"]
    }
  },
  "include": ["src/**/*"],
  "references": []
}

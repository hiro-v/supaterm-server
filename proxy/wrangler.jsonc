{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "supaterm-share-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-21",
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SHARE_RELAY",
        "class_name": "ShareRelayDurableObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ShareRelayDurableObject"]
    }
  ]
}

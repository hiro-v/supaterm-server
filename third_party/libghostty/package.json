{
  "name": "@supaterm/libghostty",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run clean && sh -c 'bun install --frozen-lockfile || bun install' && bun run build:wasm && bun run build:lib && bun run build:wasm-copy",
    "build:wasm": "./scripts/build-wasm.sh",
    "build:lib": "vite build",
    "build:wasm-copy": "cp ghostty-vt.wasm dist/",
    "clean": "rm -rf dist",
    "lint": "biome check lib scripts vite.config.js",
    "test": "bun test lib",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@happy-dom/global-registrator": "^15.11.0",
    "@types/bun": "^1.3.2",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^5.5.0",
    "mitata": "^1.0.34",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^4.5.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
